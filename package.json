{
	"name": "slowdm",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "wrangler d1 migrations apply slowdm-db --local",
		"db:migrate:remote": "wrangler d1 migrations apply slowdm-db --remote",
		"setup": "./deploy.sh setup",
		"deploy": "./deploy.sh deploy",
		"deploy:secrets": "./deploy.sh secrets"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.63.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.1",
		"bits-ui": "^2.18.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.105.0"
	}
}
