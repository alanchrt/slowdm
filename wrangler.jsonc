{
	"name": "slowdm",
	"compatibility_date": "2024-12-01",
	"pages_build_output_dir": ".svelte-kit/cloudflare",
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "slowdm-db",
			"database_id": "local",
			"migrations_dir": "drizzle"
		}
	],
	"triggers": {
		"crons": ["*/5 * * * *"]
	}
}
